groq_api_key=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Common aliases some libraries check. Keep these in sync if needed.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Needed later for real calls; not needed for free/local simulation.
OPENAI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
OPENAI_REALTIME_MODEL=gpt-realtime-2
VOICEQA_MEDIA_MODE=mock
PUBLIC_BASE_URL=https://your-public-tunnel.example.com

# Accepted aliases if you copied keys using different labels.
twilio_SID=
twilio_ClientSecret=
twilio_ClientID=
twilio_FromNumber=+1XXXXXXXXXX
twilio_number=+1XXXXXXXXXX
twilio_trial_number=+1XXXXXXXXXX
